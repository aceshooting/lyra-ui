{
  "name": "@aceshooting/lyra-flags",
  "version": "1.4.0",
  "description": "Waving country/territory flag SVGs — optional companion asset package for <lr-flag> in lyra-ui.",
  "keywords": [
    "flag-icons",
    "flags",
    "country-flags",
    "svg",
    "i18n",
    "web-components"
  ],
  "license": "SEE LICENSE IN README.md",
  "type": "module",
  "author": {
    "name": "Aceshooting",
    "email": "info@aceshooting.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aceshooting/lyra-ui.git",
    "directory": "packages/lyra-flags"
  },
  "homepage": "https://www.lyra-ui.com/",
  "bugs": {
    "url": "https://github.com/aceshooting/lyra-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "generate": "node scripts/generate-index.mjs",
    "optimize": "node scripts/optimize-flags.mjs",
    "build-compact": "node scripts/build-compact.mjs",
    "test": "node scripts/test.mjs",
    "prepack": "pnpm run generate"
  },
  "files": [
    "flags",
    "index.js",
    "index.d.ts",
    "THIRD_PARTY_NOTICES.md"
  ],
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./flags/*": "./flags/*"
  },
  "packageManager": "pnpm@11.13.0",
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "sharp": "^0.35.3",
    "svgo": "^4.0.2"
  }
}
