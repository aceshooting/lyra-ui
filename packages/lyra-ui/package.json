{
  "name": "@aceshooting/lyra-ui",
  "version": "1.3.0",
  "description": "Free, clean-room Lit web components — a companion to Web Awesome.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Aceshooting",
    "email": "info@aceshooting.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aceshooting/lyra-ui.git",
    "directory": "packages/lyra-ui"
  },
  "homepage": "https://github.com/aceshooting/lyra-ui#readme",
  "bugs": {
    "url": "https://github.com/aceshooting/lyra-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "custom-elements.json",
    "llms.txt",
    "llms-full.txt"
  ],
  "exports": {
    ".": "./dist/lyra.js",
    "./components/*": "./dist/components/*",
    "./internal/*": "./dist/internal/*"
  },
  "sideEffects": [
    "**/components/**/*.js",
    "**/components/**/*.ts",
    "./dist/lyra.js",
    "./src/lyra.ts"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "manifest": "cem analyze --litelement --outdir .",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepack": "pnpm run build && pnpm run manifest"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@types/geojson": "^7946.0.16",
    "lit": "^3.3.3"
  },
  "peerDependencies": {
    "@aceshooting/lyra-flags": "workspace:^1.2.0",
    "@sgratzl/chartjs-chart-boxplot": "^4.4.0",
    "chart.js": "^4.5.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dompurify": "^3.4.12",
    "maplibre-gl": "^5.24.0",
    "marked": "^18.0.6",
    "shiki": "^4.3.1"
  },
  "peerDependenciesMeta": {
    "@aceshooting/lyra-flags": {
      "optional": true
    },
    "@sgratzl/chartjs-chart-boxplot": {
      "optional": true
    },
    "d3-force": {
      "optional": true
    },
    "d3-drag": {
      "optional": true
    },
    "d3-zoom": {
      "optional": true
    },
    "d3-selection": {
      "optional": true
    },
    "chart.js": {
      "optional": true
    },
    "chartjs-plugin-zoom": {
      "optional": true
    },
    "dompurify": {
      "optional": true
    },
    "maplibre-gl": {
      "optional": true
    },
    "marked": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aceshooting/lyra-flags": "workspace:^1.2.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@open-wc/testing": "^4.0.0",
    "@sgratzl/chartjs-chart-boxplot": "^4.4.5",
    "@sinonjs/fake-timers": "^11.3.1",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/geojson": "^7946.0.16",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "@web/dev-server-esbuild": "^2.0.0",
    "@web/test-runner": "^1.0.0",
    "@web/test-runner-playwright": "^1.0.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
