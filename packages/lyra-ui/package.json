{
  "name": "@aceshooting/lyra-ui",
  "version": "0.1.1",
  "description": "Free, clean-room Lit web components — a companion to Web Awesome.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Aceshooting",
    "email": "info@aceshooting.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aceshooting/lyra-ui.git",
    "directory": "packages/lyra-ui"
  },
  "homepage": "https://github.com/aceshooting/lyra-ui#readme",
  "bugs": {
    "url": "https://github.com/aceshooting/lyra-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/lyra.js",
    "./components/*": "./dist/components/*",
    "./internal/*": "./dist/internal/*"
  },
  "sideEffects": [
    "**/components/**/*.js",
    "./dist/lyra.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "manifest": "cem analyze --litelement --outdir .",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "lit": "^3.3.3"
  },
  "peerDependencies": {
    "@aceshooting/lyra-flags": "^0.1.0",
    "d3-force": "^3.0.0",
    "d3-drag": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "d3-selection": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aceshooting/lyra-flags": {
      "optional": true
    },
    "d3-force": {
      "optional": true
    },
    "d3-drag": {
      "optional": true
    },
    "d3-zoom": {
      "optional": true
    },
    "d3-selection": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aceshooting/lyra-flags": "^0.1.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@open-wc/testing": "^4.0.0",
    "@types/d3-drag": "^3.0.0",
    "@types/d3-force": "^3.0.0",
    "@types/d3-selection": "^3.0.0",
    "@types/d3-zoom": "^3.0.0",
    "@web/dev-server-esbuild": "^2.0.0",
    "@web/test-runner": "^1.0.0",
    "@web/test-runner-playwright": "^1.0.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0",
  "customElements": "custom-elements.json"
}
