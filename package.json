{
  "name": "lyra-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @aceshooting/lyra-ui and its optional companion packages.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "manifest": "pnpm --filter @aceshooting/lyra-ui run manifest",
    "manifest:check": "pnpm --filter @aceshooting/lyra-ui run manifest:check",
    "dev": "storybook dev -p 6006",
    "docs": "storybook dev -p 6006",
    "docs:build": "pnpm manifest:check && storybook build -o storybook-static && pnpm docs:sitemap",
    "docs:sitemap": "node scripts/generate-sitemap.mjs",
    "docs:check-show-code": "node scripts/check-docs-show-code.mjs",
    "docs:check": "node scripts/check-docs-freshness.mjs",
    "storybook:check-theme": "node scripts/check-storybook-theme.mjs",
    "storybook:check": "node scripts/check-storybook.mjs",
    "readme:check": "node scripts/check-readme-freshness.mjs",
    "skill:check": "node scripts/check-skill-manifest.mjs",
    "check:packed-consumer": "node scripts/check-packed-consumer.mjs",
    "check:dead-code": "knip",
    "check:secrets": "node scripts/check-secrets.mjs",
    "provenance:check": "pnpm --filter @aceshooting/lyra-ui provenance-policy",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@aceshooting/lyra-flags": "workspace:*",
    "@aceshooting/lyra-ui": "workspace:*",
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.31.1",
    "@codecov/vite-plugin": "^2.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.4",
    "@sgratzl/chartjs-chart-boxplot": "^4.4.5",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/web-components": "^10.5.3",
    "@storybook/web-components-vite": "^10.5.3",
    "@tailwindcss/vite": "^4.3.3",
    "axe-core": "^4.12.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "knip": "^6.29.0",
    "lit": "^3.3.3",
    "maplibre-gl": "^6.0.0",
    "playwright": "^1.61.1",
    "publint": "^0.3.22",
    "react": "^19.2.0",
    "secretlint": "^13.0.4",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.5"
  },
  "packageManager": "pnpm@11.17.0",
  "customElements": "custom-elements.json"
}
